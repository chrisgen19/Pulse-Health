# Copy to .env.local and fill in real values
DATABASE_URL="postgres://myuser:mypassword@localhost:5432/pulsehealth"

# Better Auth
# Generate a secret with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET="replace-with-a-32-byte-random-secret"
# Base URL of the app (must match the dev port)
BETTER_AUTH_URL="http://localhost:5088"
# Optional: extra allowed origins for auth requests (comma-separated).
# e.g. preview URLs or "http://127.0.0.1:5088". Leave empty for local dev.
TRUSTED_ORIGINS=""
